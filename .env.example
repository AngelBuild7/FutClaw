# FutClaw local environment template.
# Copy to .env.local and fill values locally. Never commit real secrets.

# Public Supabase client config. Optional for community reads in local dev.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase writes. Optional for read-only/self-host demos.
SUPABASE_SERVICE_ROLE_KEY=

# GitHub GraphQL tokens. Required for live GitHub scouting.
# Use either GITHUB_TOKENS as a comma-separated pool or GITHUB_TOKEN as one token.
GITHUB_TOKENS=
GITHUB_TOKEN=

# Redis/Upstash cache. Optional; app should degrade when not configured.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional public site URL for production deployments.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
